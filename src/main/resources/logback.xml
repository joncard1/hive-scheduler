<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>%-4relative [%thread] %-5level %logger{35} -%kvp- %msg%n</Pattern>
        </layout>
    </appender>

    <appender name="SIFT" class="ch.qos.logback.classic.sift.SiftingAppender">
        <discriminator>
            <key>experiment</key>
            <defaultValue>experiments/simple/</defaultValue>
        </discriminator>

        <sift>
            <appender name="FILE-${experiment}" class="ch.qos.logback.core.FileAppender">
                <file>${experiment}logs/scheduler.log</file>
                <append>false</append>
                <immediateFlush>true</immediateFlush>
                <encoder>
                    <pattern>%-4relative [%thread] %-5level %logger{35} -%kvp- %msg%n</pattern>
                </encoder>
            </appender>
        </sift>
    </appender>

    <logger name="eusocialcooperation" level="trace">
        <appender-ref ref="SIFT"/>
    </logger>

    <root level="warn">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>